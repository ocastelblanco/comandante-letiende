rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones de ayuda ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isRootAdmin() {
      return isAuthenticated()
          && request.auth.token.email == 'letiende.co@gmail.com';
    }

    // Retorna el rol del usuario autenticado, o null si no existe su documento.
    // El documento usa el email como ID (no el UID), igual que UserService.createUser().
    // Nota: se usa operador ternario para retornar el string del rol directamente;
    // el operador && en Firestore rules retorna bool, no el último valor.
    function userRole() {
      return isAuthenticated()
          && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
          ? get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role
          : null;
    }

    function isAdmin() {
      return isRootAdmin() || userRole() == 'admin';
    }

    function isWaiter() {
      return userRole() == 'waiter';
    }

    function isBarista() {
      return userRole() == 'barista';
    }

    // Los baristas solo pueden tocar campos de estado al actualizar un pedido.
    // 'items' se incluye para que puedan marcar itemStatus de cada ítem como 'ready'.
    function onlyUpdatesOrderStatus() {
      let allowed = ['status', 'updatedAt', 'baristaId', 'preparedAt', 'items'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Los meseros solo pueden marcar un pedido como 'delivered' (entregado).
    function onlyMarksDelivered() {
      let allowed = ['status', 'updatedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed)
          && request.resource.data.status == 'delivered';
    }

    // ── Colección: users ────────────────────────────────────────────────────
    // Lectura para cualquier usuario autenticado.
    // Escrituras (alta, modificación y baja) solo para administradores.
    // Prohibido que un no-administrador altere su propio campo `role`.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Colección: products ─────────────────────────────────────────────────
    // Lectura para cualquier usuario autenticado.
    // Escrituras solo para administradores.
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Colección: orders ───────────────────────────────────────────────────
    // Mesero: leer y crear pedidos.
    // Barista: leer y actualizar únicamente campos de estado.
    // Administrador: acceso total.
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isWaiter() || isAdmin();
      allow update: if isAdmin()
          || (isBarista() && onlyUpdatesOrderStatus())
          || (isWaiter() && onlyMarksDelivered());
      allow delete: if isAdmin();
    }
  }
}
