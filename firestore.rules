rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones de ayuda ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isRootAdmin() {
      return isAuthenticated()
          && request.auth.token.email == 'letiende.co@gmail.com';
    }

    // Retorna el rol del usuario autenticado, o false si no existe su documento.
    // Usar short-circuit: false && ... => false; true && ... => valor del rol.
    function userRole() {
      return isAuthenticated()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isRootAdmin() || userRole() == 'admin';
    }

    function isWaiter() {
      return userRole() == 'waiter';
    }

    function isBarista() {
      return userRole() == 'barista';
    }

    // Los baristas solo pueden tocar campos de estado al actualizar un pedido.
    function onlyUpdatesOrderStatus() {
      let allowed = ['status', 'updatedAt', 'baristaId', 'preparedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── Colección: users ────────────────────────────────────────────────────
    // Lectura para cualquier usuario autenticado.
    // Escrituras (alta, modificación y baja) solo para administradores.
    // Prohibido que un no-administrador altere su propio campo `role`.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Colección: products ─────────────────────────────────────────────────
    // Lectura para cualquier usuario autenticado.
    // Escrituras solo para administradores.
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── Colección: orders ───────────────────────────────────────────────────
    // Mesero: leer y crear pedidos.
    // Barista: leer y actualizar únicamente campos de estado.
    // Administrador: acceso total.
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isWaiter() || isAdmin();
      allow update: if isAdmin()
          || (isBarista() && onlyUpdatesOrderStatus());
      allow delete: if isAdmin();
    }
  }
}
